# Copie para .env e preencha com os valores reais
# NÃO commitar o .env

# Banco de dados
DB_URL=jdbc:postgresql://localhost:5434/acadflow_db
DB_USERNAME=acadflow
DB_PASSWORD=sua_senha_aqui

# JWT — mínimo 32 caracteres, gerado aleatoriamente
JWT_SECRET=gere_uma_chave_segura_aqui_min_32_chars
JWT_EXPIRATION=86400000

# CORS — origens permitidas separadas por vírgula
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiting (opcional — valores padrão já aplicados)
# RATE_LIMIT_MAX_REQUESTS=10
# RATE_LIMIT_WINDOW_MS=60000
